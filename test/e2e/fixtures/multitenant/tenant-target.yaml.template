apiVersion: kollect.dev/v1alpha1
kind: KollectTarget
metadata:
  name: tenant-deployments
  namespace: ${TENANT_NS}
spec:
  profileRef: deployment-images
  namespaceSelector:
    matchLabels:
      kubernetes.io/metadata.name: ${TENANT_NS}
  labelSelector:
    matchLabels:
      kollect.dev/tenant: ${TENANT_NS}
  suspend: false
